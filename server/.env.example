PORT=5000
MONGO_URI=mongodb://localhost:27017/gigshield
NODE_ENV=development
JWT_SECRET=gigshield-demo-secret-2026

# ── Weather API (OpenWeatherMap) ────────────────────────────────────
# Free tier: https://openweathermap.org/api → sign up → copy "Default" API key
# Leave blank for mock weather data (app still works fully)
OPENWEATHER_API_KEY=

# ── Payment API (Razorpay — Test Mode) ─────────────────────────────
# Free account: https://razorpay.com → Settings → API Keys → Generate Test Key
# Leave blank to use simulated mock payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Maps ────────────────────────────────────────────────────────────
# Using Leaflet + OpenStreetMap — NO API KEY REQUIRED (always free)
